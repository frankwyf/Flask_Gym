# Flask
SECRET_KEY=replace-with-a-strong-random-secret
DEBUG=false

# Database
# Default local SQLite (recommended for first run)
DATABASE_URL=sqlite:///instance/flask_gym.db

# To use MySQL instead, comment the line above and use:
# DATABASE_URL=mysql+pymysql://username:password@127.0.0.1:3306/gym

# Mail (optional for password reset)
MAIL_SERVER=localhost
MAIL_PORT=25
MAIL_USE_SSL=false
MAIL_USE_TLS=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@example.com
